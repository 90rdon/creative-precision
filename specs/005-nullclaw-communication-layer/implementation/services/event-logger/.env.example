# Event Logger Service Configuration
PORT=18990

# PostgreSQL (Vigil central storage)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (Vigil)
REDIS_HOST=localhost
REDIS_PORT=6379

# Docker Compose override
# When using docker-compose-vigil.yml, these will be set automatically:
# DB_HOST=vigil-postgres
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=nullclaw
# DB_PASSWORD=nullclaw
# REDIS_HOST=vigil-redis
# REDIS_PORT=6379
