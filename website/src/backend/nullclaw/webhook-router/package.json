{
  "name": "@nullclaw/webhook-router",
  "version": "1.0.0",
  "description": "Webhook routing service for NullClaw agents",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "watch": "tsc --watch",
    "simulator": "node dist/simulator.js",
    "simulator:run": "node dist/simulator.js run",
    "simulator:help": "node dist/simulator.js help"
  },
  "keywords": [
    "nullclaw",
